mkdir -p /home/labs/ginossar/talfis/LiveImaging/BrightFieldEmbedding/logs

PYTHON=/home/labs/ginossar/talfis/envs/cellpose_embed/bin/python
SCRIPT=/home/labs/ginossar/talfis/LiveImaging/BrightFieldEmbedding/Attention_maps/01_attention_maps.py

